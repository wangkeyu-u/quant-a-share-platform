# ============================================================
# AI 网关配置(OpenAI 兼容协议)
# 本地 ML 推理(GBM 双模型)始终启用,不依赖以下变量。
# 远程大模型(新闻情绪 / 报告摘要 / 行情点评)只有在下面两个变量
# 都设置后才会启用;未设置时相关调用会优雅跳过,不影响主流程。
# ============================================================

# 远程 LLM 的 base url(OpenAI 兼容,结尾带或不带 /v1 均可)
AI_GATEWAY_BASE_URL=https://api.openai.com/v1

# API key
AI_GATEWAY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 模型名(任意 OpenAI 兼容模型,如 gpt-4o-mini / deepseek-chat / qwen 等)
AI_GATEWAY_MODEL=gpt-4o-mini

# 可选:单次请求超时(秒)
AI_GATEWAY_TIMEOUT=60
